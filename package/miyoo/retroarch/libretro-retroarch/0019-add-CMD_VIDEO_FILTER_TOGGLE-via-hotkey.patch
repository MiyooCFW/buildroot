+   MSG_VIDEO_FILTER_ENABLE_ON,
+   MSG_VIDEO_FILTER_ENABLE_OFF,
 
    MSG_IOS_TOUCH_MOUSE_ENABLED,
    MSG_IOS_TOUCH_MOUSE_DISABLED,
